<style>
  .blog-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .blog-table-wrap {
    overflow-x: auto;
    margin-top: 30px;
  }

  table.blog-table {
    width: 100%;
    border-collapse: collapse;
    background: #000;
    color: #fff;
  }

  table.blog-table th,
  table.blog-table td {
    padding: 12px 14px;
    border-bottom: 1px solid #222;
    font-size: 14px;
    white-space: nowrap;
  }

  table.blog-table th {
    position: sticky;
    top: 0;
    background: #000;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  table.blog-table th span {
    color: #aaa;
    cursor: default;
  }

  table.blog-table td a {
    color: #3bbcff;
    text-decoration: none;
  }

  table.blog-table td a:hover {
    text-decoration: underline;
  }

  table.blog-table tr:hover {
    background: #0d0d0d;
  }
</style>

<div class="blog-container">
  <div class="blog-table-wrap">
    <table class="blog-table">
      <thead>
        <tr>
          <th><span>Title ⇅</span></th>
          <th><span>Published ⇅</span></th>
          <th><span>Profile</span></th>
        </tr>
      </thead>
      <tbody>
        {% for article in blog.articles %}
        <tr>
          <td>
            <a href="{{ article.url }}">
              {{ article.title }}
            </a>
          </td>
          <td>
            {{ article.published_at | date: "%Y" }}
          </td>
          <td>
            <a href="{{ article.url }}">View</a>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</div>