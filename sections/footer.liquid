{% comment %}
** Footer - restrained publisher view **
- Static section
{% endcomment %}

<footer class="footer">
  <div class="container footer-menu-wrap footer-publisher-shell">
    <div class="footer-publisher-grid">
      <div class="footer-publisher-brand">
        <p class="footer-brand-line">{{ shop.name }}</p>
        <p class="footer-mission">Independent publishing focused on breaking news, crime, corruption, public accountability, submitted evidence, and developing public-interest stories.</p>
      </div>

      <nav class="footer-link-group" aria-label="News links">
        <h6>News</h6>
        <ul>
          <li><a href="/blogs/breaking-news">Breaking News</a></li>
          <li><a href="/pages/archives">Archives</a></li>
          <li><a href="/pages/submit-a-tip">Submit a Tip</a></li>
        </ul>
      </nav>

      <nav class="footer-link-group" aria-label="About and trust links">
        <h6>About and Trust</h6>
        <ul>
          <li><a href="/pages/about-shadab-chow">About Shadab Chow</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/pages/editorial-standards">Editorial Standards</a></li>
          <li><a href="/pages/corrections-policy">Corrections Policy</a></li>
          {% if shop.customer_accounts_enabled %}
            <li><a href="/account">Account</a></li>
          {% endif %}
        </ul>
      </nav>

      <nav class="footer-link-group" aria-label="Legal and advertising links">
        <h6>Legal and Advertising</h6>
        <ul>
          <li><a href="/pages/privacy-policy">Privacy Policy</a></li>
          <li><a href="/pages/terms-of-use">Terms of Use</a></li>
          <li><a href="/pages/copyright-policy">Copyright / DMCA Policy</a></li>
          <li><a href="/pages/advertise-sponsor">Advertise/Sponsor</a></li>
        </ul>
      </nav>
    </div>

    <div class="sixteen columns row footer_credits footer-publisher-credits">
      <p class="credits">
        &copy; {{ "now" | date: "%Y" }} {{ shop.name | link_to: '/' }}.
        {{ section.settings.copyright_text }}
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-publisher-shell {
    padding-top: 42px;
    padding-bottom: 26px;
  }

  .footer-publisher-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.3fr) repeat(3, minmax(0, 1fr));
    gap: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand-line,
  .footer-link-group h6,
  .footer-link-group a,
  .footer-publisher-credits .credits {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  .footer-brand-line {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #efefef;
    margin-bottom: 14px;
  }

  .footer-mission {
    max-width: 34ch;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(239, 239, 239, 0.72);
    margin: 0;
  }

  .footer-link-group h6 {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #efefef;
    margin-bottom: 14px;
  }

  .footer-link-group ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .footer-link-group li + li {
    margin-top: 10px;
  }

  .footer-link-group a {
    color: rgba(239, 239, 239, 0.72);
    text-decoration: none;
    font-size: 14px;
    line-height: 1.5;
  }

  .footer-link-group a:hover {
    color: #efefef;
  }

  .footer-publisher-credits {
    padding-top: 18px;
  }

  .footer-publisher-credits .credits {
    font-size: 12px;
    letter-spacing: 0.04em;
  }

  @media (max-width: 960px) {
    .footer-publisher-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .footer-publisher-grid {
      grid-template-columns: 1fr;
    }
  }

</style>

{% schema %}

{
  "name": "Footer",
  "class": "footer-section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright text"
    },
    {
      "type": "checkbox",
      "id": "display_designed_by",
      "label": "Show theme designer credits",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "display_payment_methods",
      "label": "Show payment method icons",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "Logo alignment",
          "options": [
            {
              "value": "left",
              "label": "Left"
            },
            {
              "value": "center",
              "label": "Center"
            },
            {
              "value": "right",
              "label": "Right"
            }
          ],
          "default": "left"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social media footer icons",
          "default": false
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "info": "This menu won't show dropdown items"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social media footer icons",
          "default": false
        }
      ]
    },
    {
      "type": "page",
      "name": "Page",
      "limit": 1,
      "settings": [
        {
          "type": "page",
          "id": "page",
          "label": "Content page"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social media footer icons",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Footer content</p>"
        },
        {
          "type": "checkbox",
          "id": "social_icons_footer",
          "label": "Show social media footer icons",
          "default": false
        }
      ]
    },
    {
      "type": "empty",
      "name": "Empty column",
      "settings": []
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "logo"
      },
      {
        "type": "link_list"
      },
      {
        "type": "text"
      }
    ]
  }
}

{% endschema %}
