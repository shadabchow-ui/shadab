{% assign breaking_blog_url = '/blogs/breaking-news' %}
{% assign submit_tip_url = '/pages/submit-a-tip' %}
{% assign about_url = '/pages/about-shadab-chow' %}
{% assign contact_url = '/pages/contact' %}
{% assign editorial_url = '/pages/editorial-standards' %}
{% assign corrections_url = '/pages/corrections-policy' %}
{% assign privacy_url = '/pages/privacy-policy' %}

<div class="newsroom-home">
  <section class="hero">
    <div class="hero-copy">
      <div class="hero-kicker">Independent publisher · Breaking news · Public accountability</div>
      <h1 class="hero-hed">Breaking news, crime coverage, corruption reporting, and public-interest accountability by Shadab Chow.</h1>
      <p class="hero-sub">Independent reporting on developing stories, public safety, corruption, accountability, and the people and systems shaping everyday life.</p>
      <div class="hero-ctas">
        <a href="{{ breaking_blog_url }}" class="btn btn-primary">Breaking News</a>
        <a href="{{ submit_tip_url }}" class="btn btn-secondary">Submit a Tip</a>
      </div>
    </div>

    <div class="hero-panel">
      <div class="hero-panel__label">Publisher Focus</div>
      <ul class="hero-panel__list">
        <li>Breaking developments, verified updates, and public-safety coverage</li>
        <li>Crime, corruption, and accountability reporting with clear context</li>
        <li>Tips, corrections, editorial standards, and source transparency</li>
      </ul>
    </div>
  </section>

  <section class="mission">
    <div class="inner section-grid">
      <div>
        <div class="label">Mission</div>
        <h2 class="section-title">Report what happened. Explain why it matters. Update the record when facts change.</h2>
      </div>
      <div class="body-copy">
        <p>Coverage follows public-interest stories where the stakes are real: breaking incidents, crime and public safety, corruption, misconduct, submitted evidence, and accountability reporting.</p>
        <p>The goal is straightforward: publish useful reporting, separate confirmed facts from claims, and keep readers close to corrections, standards, contact information, and tip submission.</p>
      </div>
    </div>
  </section>

  <section class="coverage">
    <div class="inner">
      <div class="label">Coverage Areas</div>
      <div class="coverage-grid">
        <article class="coverage-card">
          <h3>Breaking News</h3>
          <p>Fast-moving developments, public-safety incidents, and timely updates as new information is verified.</p>
        </article>
        <article class="coverage-card">
          <h3>Crime and Public Safety</h3>
          <p>Reporting that separates allegations, arrests, official statements, and confirmed facts with care.</p>
        </article>
        <article class="coverage-card">
          <h3>Corruption and Accountability</h3>
          <p>Coverage focused on misuse of power, institutional failures, public records, and scrutiny of people in authority.</p>
        </article>
        <article class="coverage-card">
          <h3>Exclusive Footage and Tips</h3>
          <p>Reader-submitted documents, footage, and leads reviewed for public-interest value and editorial relevance.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="standards">
    <div class="inner section-grid">
      <div>
        <div class="label">Editorial Approach</div>
        <h2 class="section-title">Independent reporting backed by visible standards, corrections, and contact paths.</h2>
      </div>
      <div class="body-copy">
        <p>Trust pages, correction policies, privacy information, and contact links stay easy to find so readers can evaluate the work and reach the publisher directly.</p>
        <div class="trust-links">
          <a href="{{ editorial_url }}">Editorial Standards</a>
          <a href="{{ corrections_url }}">Corrections Policy</a>
          <a href="{{ privacy_url }}">Privacy Policy</a>
          <a href="{{ contact_url }}">Contact</a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-strip">
    <div class="inner">
      <div class="label">Start Here</div>
      <div class="cta-grid">
        <a class="cta-card" href="{{ breaking_blog_url }}">
          <span class="cta-card__label">Read</span>
          <strong>Breaking News</strong>
          <span>Follow the latest reporting, developing stories, and public-interest updates.</span>
        </a>
        <a class="cta-card" href="{{ breaking_blog_url }}">
          <span class="cta-card__label">Browse</span>
          <strong>Crime &amp; Accountability</strong>
          <span>Find coverage on crime, corruption, public safety, and institutional accountability.</span>
        </a>
        <a class="cta-card" href="{{ submit_tip_url }}">
          <span class="cta-card__label">Send</span>
          <strong>Submit a Tip</strong>
          <span>Share documents, footage, and public-interest leads for editorial review.</span>
        </a>
        <a class="cta-card" href="{{ about_url }}">
          <span class="cta-card__label">About</span>
          <strong>About Shadab Chow</strong>
          <span>Learn about the publisher, mission, and editorial approach behind the site.</span>
        </a>
      </div>
    </div>
  </section>
</div>
