{% assign source_note_title = source_note_title | default: 'Source note' %}
{% assign source_note_body = source_note_body | default: 'Source material, images, and embeds are presented as published or supplied at the time of reporting. Independent verification may still be ongoing where the article does not state otherwise.' %}
{% assign source_note_footnote = source_note_footnote | default: 'Specific structured source fields are not provided in repo code, so this component avoids inventing sourcing details.' %}

<section class="news-note news-note--source no-ad-zone no-ad-zone--sensitive" aria-label="Source context note">
  <h2 class="news-note__title">{{ source_note_title }}</h2>
  <p class="news-note__body">{{ source_note_body }}</p>
  <p class="news-note__footnote">{{ source_note_footnote }}</p>
</section>
