{% comment %}
  Facebook Open Graph meta tags
{% endcomment %}

{% assign social_meta_title = meta_title | default: page_title %}
{% assign social_meta_description = meta_description | default: page_description %}

<meta name="author" content="{{ shop.name }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:site_name" content="{{ shop.name }}">

{% if template contains 'product' %}
  {% comment %}Publisher site: product pages are noindexed. og:type=product and price metadata suppressed.{% endcomment %}
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ shop.name | escape }}">
{% elsif template contains 'collection' %}
  {% comment %}Publisher site: collection pages are noindexed. Suppressed product.group og:type to avoid signaling storefront to crawlers.{% endcomment %}
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ shop.name | escape }}">
{% elsif template contains 'article' %}
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ article.title | strip_html | escape }}">
  <meta property="article:published_time" content="{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:modified_time" content="{{ article.updated_at | default: article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}">
  <meta property="article:author" content="{% if article.author != blank and article.author != shop.name %}{{ article.author | escape }}{% else %}Shadab Chow{% endif %}">
  <meta property="og:description" content="{{ article.excerpt_or_content | strip_html | truncatewords: 40, '' | escape }}">
  {% assign img_tag = '<' | append: 'img' %}
  {% if article.image %}
    <meta property="og:image" content="https:{{ article.image | img_url: '1200x' }}">
    <meta property="og:image:secure_url" content="https:{{ article.image | img_url: '1200x' }}">
  {% elsif article.content contains img_tag %}
    {% assign src = article.content | split: 'src="' %}
    {% assign src = src[1] | split: '"' | first | remove: 'https:' | remove: 'http:' %}
    {% if src %}
      <meta property="og:image" content="https:{{ src }}">
      <meta property="og:image:secure_url" content="https:{{ src }}">
    {% endif %}
  {% endif %}
{% elsif template contains 'blog' %}
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ blog.title | strip_html | escape }}">
  {% if blog.articles_count > 0 %}
    {% assign article = blog.articles.first %}
    {% assign img_tag = '<' | append: 'img' %}
    {% if article.image %}
      <meta property="og:image" content="http:{{ article.image | img_url: '600x' }}">
      <meta property="og:image:secure_url" content="https:{{ article.image | img_url: '600x' }}">
    {% elsif article.content contains img_tag %}
      {% assign src = article.content | split: 'src="' %}
      {% assign src = src[1] | split: '"' | first | remove: 'https:' | remove: 'http:' %}
      {% if src %}
        <meta property="og:image" content="http:{{ src }}">
        <meta property="og:image:secure_url" content="https:{{ src }}">
      {% endif %}
    {% endif %}
  {% endif %}
{% elsif template contains 'page' %}
  <meta property="og:type" content="article">
  <meta property="og:title" content="{{ social_meta_title | strip_html | escape }}">
  {% assign img_tag = '<' | append: 'img' %}
  {% if page.content contains img_tag %}
    {% assign src = page.content | split: 'src="' %}
    {% assign src = src[1] | split: '"' | first | remove: 'https:' | remove: 'http:' %}
    {% if src %}
      <meta property="og:image" content="http:{{ src }}">
      <meta property="og:image:secure_url" content="https:{{ src }}">
    {% endif %}
  {% endif %}
{% else %}
  <meta property="og:type" content="website">
  <meta property="og:title" content="{{ social_meta_title | escape }}">
{% endif %}
{% if social_meta_description %}
  <meta property="og:description" content="{{ social_meta_description | escape }}">
{% endif %}

{% comment %}
  Twitter user name of the site, based on theme settings
{% endcomment %}
{% if settings.twitter_link != blank %}
  <meta name="twitter:site" content="{{ settings.twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{% endif %}
<meta name="twitter:card" content="{% if template contains 'article' %}summary_large_image{% else %}summary{% endif %}">
{% if template contains 'product' %}
  <meta name="twitter:title" content="{{ product.title }}">
  <meta name="twitter:description" content="{{ product.description | strip_html | truncatewords: 140, '' | escape }}">
  <meta name="twitter:image" content="https:{{ product.featured_image.src | img_url: '240x' }}">
  <meta name="twitter:image:width" content="240">
  <meta name="twitter:image:height" content="240">
{% elsif template contains 'article' %}
  <meta name="twitter:title" content="{{ article.title }}">
  <meta name="twitter:description" content="{{ article.excerpt_or_content | strip_html | truncatewords: 140, '' | escape }}">
  {% if article.image %}
    <meta property="twitter:image" content="https:{{ article.image | img_url: '1200x' }}">
  {% elsif article.content contains "<img" %}
    {% assign src = article.content | split: 'src="' %}
    {% assign src = src[1] | split: '"' | first | replace: '//cdn', 'https://cdn' | replace: 'https:https://', 'https://' | remove: 'http:' %}
    {% if src %}
      <meta property="twitter:image" content="{{ src }}">
    {% endif %}
  {% endif %}
{% elsif template contains 'page' %}
  <meta name="twitter:title" content="{{ social_meta_title | escape }}">
  {% if social_meta_description %}
    <meta name="twitter:description" content="{{ social_meta_description | escape }}">
  {% endif %}
{% endif %}
