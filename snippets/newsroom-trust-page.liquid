<article class="newsroom-page newsroom-page--{{ newsroom_page_kind }}">
  <header class="newsroom-page__header">
    <p class="newsroom-page__kicker">Publisher Information</p>
    <h1 class="newsroom-page__title">{{ page.title }}</h1>
    {% if newsroom_page_lede != blank %}
      <p class="newsroom-page__lede">{{ newsroom_page_lede | strip }}</p>
    {% endif %}
  </header>

  <div class="newsroom-page__body rte">
    {% if page.content != blank %}
      {{ page.content }}
    {% else %}
      {{ newsroom_page_fallback }}
    {% endif %}
  </div>

  {% unless newsroom_page_kind == 'privacy' or newsroom_page_kind == 'terms' or newsroom_page_kind == 'copyright' %}
    {% include 'submit-tip-cta' %}
  {% endunless %}
</article>

<style>
  .newsroom-page {
    width: min(100% - 24px, 980px);
    margin: 0 auto;
    padding: 56px 0 88px;
    color: #efefef;
  }

  .newsroom-page__header {
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 22px;
    margin-bottom: 28px;
  }

  .newsroom-page__kicker {
    font-family: "IBM Plex Mono", monospace;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(239, 239, 239, 0.56);
  }

  .newsroom-page__title {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(40px, 5vw, 72px);
    line-height: 0.98;
    letter-spacing: -0.03em;
    margin: 14px 0 12px;
  }

  .newsroom-page__lede {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.45;
    font-style: italic;
    color: rgba(239, 239, 239, 0.72);
    max-width: 760px;
  }

  .newsroom-page__body {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.7;
    color: #efefef;
  }

  .newsroom-page__body p,
  .newsroom-page__body ul,
  .newsroom-page__body ol,
  .newsroom-page__body h2,
  .newsroom-page__body h3,
  .newsroom-page__body pre {
    max-width: 760px;
    margin-left: auto;
    margin-right: auto;
  }

  .newsroom-page__body ul,
  .newsroom-page__body ol {
    padding-left: 22px;
  }

  .newsroom-page__body li {
    margin-bottom: 10px;
  }

  .newsroom-page__body h2,
  .newsroom-page__body h3 {
    font-family: "IBM Plex Mono", monospace;
    font-size: 14px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 38px;
    margin-bottom: 14px;
  }

  .newsroom-page__body code {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.8em;
  }

  .newsroom-page__body pre {
    overflow-x: auto;
    padding: 18px 20px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media only screen and (max-width: 767px) {
    .newsroom-page {
      padding: 40px 0 64px;
    }

    .newsroom-page__body {
      font-size: 18px;
      line-height: 1.75;
    }
  }
</style>
