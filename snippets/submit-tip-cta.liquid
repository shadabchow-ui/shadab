{% assign tip_page = pages['submit-a-tip'] %}
{% assign tip_page_url = '/pages/submit-a-tip' %}
{% if tip_page != blank and tip_page.url != blank %}
  {% assign tip_page_url = tip_page.url %}
{% endif %}

{% comment %}Future ad placement guardrail: keep ads away from tip/contact actions and adjacent source-safety copy.{% endcomment %}
<section class="news-note news-note--tip no-ad-zone no-ad-zone--tipline" aria-label="Submit a tip call to action">
  <h2 class="news-note__title">Submit a Tip</h2>
  <p class="news-note__body">Submit a tip, document, photo, public record, or other public-interest lead. Submitting information does not guarantee publication, response, confidentiality, payment, or legal protection.</p>
  <p class="news-note__footnote"><a href="{{ tip_page_url }}">Go to the tip form</a></p>
</section>
